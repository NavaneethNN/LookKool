# ──────────────────────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────────────────────
# Found at: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ──────────────────────────────────────────────────────────────
# Database (Drizzle ORM)
# ──────────────────────────────────────────────────────────────
# Transaction Pooler (port 6543) — used at RUNTIME
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Session Pooler (port 5432) — used by drizzle-kit for migrations only
DATABASE_DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres

# ──────────────────────────────────────────────────────────────
# Razorpay
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ──────────────────────────────────────────────────────────────
# App
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000



